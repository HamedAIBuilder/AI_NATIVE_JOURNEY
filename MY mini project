def add_new_user(user_id, name, favorite_song_id=None):
    """
    Adds a new user to the global users_data list.
    This demonstrates managing user data.

    Args:
        user_id (str): A unique identifier for the user.
        name (str): The name of the user.
        favorite_song_id (int, optional): The ID of the user's favorite song. Defaults to None.
    """
    new_user = {
        "user_id": user_id,
        "name": name,
        "favorite_song_id": favorite_song_id,
        "songs_sung_count": 0 # New users start with 0 songs sung
    }
    users_data.append(new_user)
    print(f"\nWelcome, {name}! You've been added to our Happy Voices family! 👋")


