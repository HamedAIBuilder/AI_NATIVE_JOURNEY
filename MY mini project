def load_song_lyrics(song_id=1):
    """
    Loads the lyrics for a chosen song from the global songs_data.

    This function represents the 'Get Ready, Get Set, Lyrics!' step.
    It now uses a list of dictionaries to store and retrieve song information.

    Args:
        song_id (int): The 'id' of the chosen song from the songs_data list.

    Returns:
        list: A list of strings, where each string is a lyric line for the chosen song.
              Returns an empty list if the song_id is not found.
    """
    print("🌟 Getting ready for your song! 🌟")
    time.sleep(1) # A little dramatic pause for loading

    for song in songs_data:
        if song["id"] == song_id:
            print(f"🎶 Loaded: {song['title']}! 🎶")
            return song["lyrics"]

    print("Oops! I don't know that song yet. Let's sing Twinkle, Twinkle by default!")
    # If song_id is not found, recursively call with default ID
    return load_song_lyrics(1)


def display_lyrics_with_pacing(lyrics_list, pace_seconds=2.5):
    """
    Displays each lyric line with a comfortable pause, simulating the 'Just Right' Pacing Pal.

    This is the 'Sing-Along Display' step. It ensures words appear at a child-friendly speed.

    Args:
        lyrics_list (list): A list of strings, where each string is a lyric line.
        pace_seconds (float): The number of seconds to pause after displaying each line.
                              This represents the 'Just Right' Pacing Pal's fixed speed.
    """
    print("\n--- Let's Sing! ---")
    print("Get ready to see the words...")
    time.sleep(pace_seconds / 2) # Shorter pause before the first line

    for i, line in enumerate(lyrics_list):
        print(f"\n🎵 {line} 🎵")
        # Pause for the "Just Right" Pacing Pal
        time.sleep(pace_seconds)

        # Call the cheer squad periodically, e.g., after every 2 lines
        # Avoid cheering after blank lines or if it's the very last line
        if line.strip() != "" and (i + 1) % 2 == 0 and i < len(lyrics_list) - 1:
            generate_cheer()
            time.sleep(1) # Small pause after cheer

    print("\n--- Song Finished! ---")
    print("You did a wonderful job!")


def generate_cheer():
    """
    Generates a random, encouraging cheer message from the 'Happy Cheer Squad'.

    This function represents the 'Hooray! You Did It!' step.
    It now uses the global cheer_messages list for its dynamic positive reinforcement.
    """
    print(f"\n✨ {random.choice(cheer_messages)} ✨")


